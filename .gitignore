# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# serwist build artifacts (re-emitted on every build)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map
/public/workbox-*.js
/public/workbox-*.js.map

# local QA / scratch artifacts — do NOT publish
# (/*.png ignores only root-level screenshots; public/AI.png is kept)
# (delete the rowena.pdf line below if you intentionally want the paper public)
.playwright-mcp/
/*.png
rowena.pdf
docs/superpowers/
